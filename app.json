{
  "expo": {
    "name": "Pulses",
    "slug": "pulses",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pulses",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulses.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pulses.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Pulses — E2E Encrypted Chat",
      "shortName": "Pulses",
      "description": "End-to-end encrypted messaging for groups and direct messages.",
      "themeColor": "#6366f1",
      "backgroundColor": "#ffffff",
      "display": "standalone"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
