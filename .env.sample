# ── Local development ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# URL of the Cloudflare Worker sync server (for local dev, run: cd server && pnpm dev)
EXPO_PUBLIC_SYNC_URL=http://localhost:8787/v1

# ── Server (server/wrangler.toml [vars]) ──────────────────────────────────────
# Set via `wrangler secret put` or directly in the Cloudflare dashboard.
# Not used by the client — only by the Cloudflare Worker.

# ENCRYPTION_SECRET=change-me-in-production

# ── CI / GitHub Actions secrets ───────────────────────────────────────────────
# Set these in GitHub → Settings → Secrets and variables → Actions.
# Never commit real values.

# CLOUDFLARE_API_TOKEN=     # Cloudflare API token (Workers + Pages deploy permissions)
# CLOUDFLARE_ACCOUNT_ID=    # Your Cloudflare account ID
# EXPO_TOKEN=               # Expo access token (required for EAS APK builds)

# ── CI / GitHub Actions variables ─────────────────────────────────────────────
# Set these in GitHub → Settings → Secrets and variables → Actions → Variables.

# EXPO_PUBLIC_SYNC_URL=     # Production sync server URL, injected at build time
